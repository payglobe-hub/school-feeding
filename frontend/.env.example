# ==========================================
# FIREBASE CONFIGURATION
# ==========================================
# Replace these with your actual Firebase project configuration values
# You can find these in your Firebase Console -> Project Settings -> General -> Your apps

REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# ==========================================
# APPLICATION ENVIRONMENT
# ==========================================
# Set to 'production' for live deployment, 'development' for local development
NODE_ENV=development

# ==========================================
# FRONTEND SPECIFIC
# ==========================================
# Google Analytics (optional)
REACT_APP_GA_TRACKING_ID=your_ga_tracking_id

# Payment integration (Stripe)
REACT_APP_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Map integration (Leaflet)
REACT_APP_MAPBOX_ACCESS_TOKEN=your_mapbox_token

# ==========================================
# SHARED FEATURES
# ==========================================
# Enable/disable real-time synchronization
REACT_APP_ENABLE_REAL_TIME_SYNC=true

# Enable/disable push notifications
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=false

# Content workflow settings
REACT_APP_ENABLE_CONTENT_WORKFLOW=true

# Analytics dashboard
REACT_APP_ENABLE_ANALYTICS_DASHBOARD=true

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================
# Mock data for development (set to false in production)
REACT_APP_USE_MOCK_DATA=true

# Debug mode
REACT_APP_DEBUG_MODE=true

# API endpoints (if using external APIs)
REACT_APP_API_BASE_URL=https://api.gsfp.gov.gh
REACT_APP_MEDIA_BASE_URL=https://media.gsfp.gov.gh
